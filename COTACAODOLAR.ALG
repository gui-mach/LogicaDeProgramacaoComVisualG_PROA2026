Algoritmo "COTACAODOLAR"
// Disciplina   : [ Lógica de Programaçăo com visual g ]
// Professor   : Jailson Costa dos Santos 
// Descriçăo   :Converte um valor em Dólares para Reais baseado na cotaçăo
// Autor(a)    : Guilherme Machado
// Data atual  : 17/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
COTACAO, QUANTIDADE_DOLAR, VALOR_REAL: Real

inicio
   // Entrada de dados
   Escreval("--- CONVERSOR DE MOEDA (USD -> BRL) ---")
   Escreva("Digite a cotaçăo atual do dólar (R$): ")
   Leia(COTACAO)
   Escreva("Digite a quantidade de dólares disponível: US$ ")
   Leia(QUANTIDADE_DOLAR)

   // Processamento
   // Cálculo: Valor em Real = Quantidade de Dólares * Cotaçăo
   VALOR_REAL <- QUANTIDADE_DOLAR * COTACAO

   // Saída de resultados
   Escreval("---------------------------------------")
   Escreval("Cotaçăo informada: R$ ", COTACAO:5:2)
   Escreval("Valor em Dólar   : US$ ", QUANTIDADE_DOLAR:5:2)
   Escreval("VALOR EM REAIS   : R$ ", VALOR_REAL:5:2)
   Escreval("---------------------------------------")
   Fimalgoritmo