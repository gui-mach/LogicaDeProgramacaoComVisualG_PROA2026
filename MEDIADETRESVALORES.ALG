Algoritmo "mediadeTresValores"
// Disciplina  : [ Lógica de Programaçăo com visual g ]
// Professor   : Jailson Costa dos Santos 
// Descriçăo   : solicita os valores para dividir e realizar a media
// Autor(a)    : Guilherme Machado da Silva
// Data atual  : 30/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
valor01,valor02,valor03:real
resultado:real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreval("Digite o primeiro valor")
leia(valor01)
escreval("Digite o segundo valor")
leia(valor02)
escreval("Digite o terceiro valor")
leia(valor03)
resultado<- (valor01+valor02+valor03)/3
escreval("A media dos valores é ",resultado)

Fimalgoritmo