Algoritmo "CalculoMedia"
// Disciplina   : [ Lógica de Programaçăo com visual g ]
// Professor   : Jailson Costa dos Santos 
// Descriçăo   :Calcula a média e verifica se o aluno foi aprovado (média 5)
// Autor(a)    : Guilherme Machado
// Data atual  : 17/04/2026
var
   n1, n2, n3, n4, media: real

inicio
   // Entrada das quatro notas
   escreva("Digite a primeira nota: ")
   leia(n1)
   escreva("Digite a segunda nota: ")
   leia(n2)
   escreva("Digite a terceira nota: ")
   leia(n3)
   escreva("Digite a quarta nota: ")
   leia(n4)

   // Cálculo da média aritmética
   media <- (n1 + n2 + n3 + n4) / 4

   // Verificaçăo da condiçăo de aprovaçăo
   escreval("---------------------------------------")
   se (media >= 5) entao
      escreval("Status: ALUNO APROVADO")
   senao
      escreval("Status: ALUNO REPROVADO")
   fimse

   // Apresentaçăo da média para qualquer condiçăo
   escreval("Média final: ", media:4:2)
   escreval("---------------------------------------")

   Fimalgoritmo